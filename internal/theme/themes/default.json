{
  "meta": {
    "name": "default",
    "version": "1.0",
    "mode": "dark"
  },
  "palette": {
    "background": {
      "primary": "#1A1816",
      "panel": "#2A2825",
      "elevated": "#3A3835"
    },
    "text": {
      "primary": "#FAF3E8",
      "secondary": "#E8D5B7",
      "muted": "#8B8680",
      "dim": "#5C5955",
      "inverse": "#1A1816"
    },
    "accent": {
      "primary": "#D4A843",
      "secondary": "#C4873B",
      "tertiary": "#7D9B76"
    },
    "state": {
      "success": "#7D9B76",
      "error": "#A0522D",
      "warning": "#C4873B",
      "info": "#8B8680"
    }
  },
  "border": {
    "style": "rounded",
    "foreground": "text.dim"
  },
  "components": {
    "panel": {
      "border_foreground": "text.dim",
      "title_foreground": "accent.primary"
    },
    "text": {
      "heading": "accent.primary",
      "body": "text.primary",
      "code": "accent.secondary",
      "link": "accent.tertiary",
      "blockquote": "text.muted",
      "list_marker": "accent.secondary"
    },
    "input": {
      "text": "text.secondary",
      "placeholder": "text.dim",
      "cursor": "accent.primary",
      "label": "accent.secondary"
    },
    "status": {
      "normal_bg": "accent.primary",
      "normal_fg": "text.inverse",
      "insert_bg": "accent.tertiary",
      "insert_fg": "text.inverse",
      "command_bg": "accent.secondary",
      "command_fg": "text.inverse",
      "bar_bg": "background.panel",
      "bar_fg": "text.muted"
    },
    "graph": {
      "bar": "accent.primary",
      "label": "text.muted",
      "grid": "text.dim"
    }
  },
  "effects": {
    "glow": false,
    "scanline": false,
    "noise": false
  },
  "behavior": {
    "density": "normal"
  }
}
