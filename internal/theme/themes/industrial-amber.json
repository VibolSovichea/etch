{
  "meta": {
    "name": "industrial-amber",
    "version": "1.0",
    "mode": "dark"
  },
  "palette": {
    "background": {
      "primary": "#000000",
      "panel": "#1A1200",
      "elevated": "#261A00"
    },
    "text": {
      "primary": "#FFA500",
      "secondary": "#CC8400",
      "muted": "#996300",
      "dim": "#664200",
      "inverse": "#000000"
    },
    "accent": {
      "primary": "#FFB000",
      "secondary": "#FF8C00",
      "tertiary": "#CC7000"
    },
    "state": {
      "success": "#00FF41",
      "error": "#FF3333",
      "warning": "#FFD700",
      "info": "#FFB000"
    }
  },
  "border": {
    "style": "normal",
    "foreground": "text.dim"
  },
  "components": {
    "panel": {
      "border_foreground": "text.muted",
      "title_foreground": "accent.primary"
    },
    "text": {
      "heading": "accent.primary",
      "body": "text.primary",
      "code": "accent.secondary",
      "link": "accent.tertiary",
      "blockquote": "text.muted",
      "list_marker": "accent.secondary"
    },
    "input": {
      "text": "text.secondary",
      "placeholder": "text.dim",
      "cursor": "accent.primary",
      "label": "accent.secondary"
    },
    "status": {
      "normal_bg": "accent.primary",
      "normal_fg": "text.inverse",
      "insert_bg": "state.success",
      "insert_fg": "text.inverse",
      "command_bg": "accent.secondary",
      "command_fg": "text.inverse",
      "bar_bg": "background.panel",
      "bar_fg": "text.muted"
    },
    "graph": {
      "bar": "accent.primary",
      "label": "text.muted",
      "grid": "text.dim"
    }
  },
  "effects": {
    "glow": true,
    "scanline": true,
    "noise": false
  },
  "behavior": {
    "density": "compact"
  }
}
